# ═══════════════════════════════════════════════════════════════════════════════
# SPECTRA — Root Environment Variables (used by Docker Compose)
# Copy to .env and fill in all required values before running:
#   docker-compose up -d
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false

# Fernet encryption key for TOTP secrets at rest.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=CHANGE_ME_32_CHARS_MINIMUM

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
POSTGRES_DB=spectra
POSTGRES_USER=spectra
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_32_CHARS_MINIMUM
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_2FA_TEMP_EXPIRE_MINUTES=5

# ── CORS ─────────────────────────────────────────────────────────────────────
# Replace with your actual frontend domain
ALLOWED_ORIGINS=https://spectra.yourdomain.com

# ── Frontend build ────────────────────────────────────────────────────────────
# Must point to the production API URL visible from the browser
VITE_API_BASE_URL=https://spectra.yourdomain.com/api/v1

# ── TOTP ─────────────────────────────────────────────────────────────────────
TOTP_ISSUER=SPECTRA

# ── Usage limits ─────────────────────────────────────────────────────────────
MAX_RUNS_PER_DAY=0            # 0 = unlimited
MAX_TARGETS=0                 # 0 = unlimited
MAX_RUN_TIMEOUT_SECONDS=120

# ── Data retention ───────────────────────────────────────────────────────────
DATA_RETENTION_DAYS=90

# ── Optional integrations ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── TLS / certbot ────────────────────────────────────────────────────────────
# Used by config/scripts/gen_certs.sh and certbot service
CERTBOT_EMAIL=kris.yvna@gmail.com
CERTBOT_DOMAIN=spectra.yourdomain.com
