# Aplicación
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
APP_DEBUG=true

# Base de datos
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=spectra
POSTGRES_USER=spectra
POSTGRES_PASSWORD=change-me

# Backend
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost

# Frontend
VITE_API_BASE_URL=https://localhost/api/v1

# JWT (generar con: python -c "import secrets; print(secrets.token_hex(64))")
JWT_SECRET_KEY=change-me-with-64-byte-hex-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_2FA_TEMP_EXPIRE_MINUTES=5

# TOTP
TOTP_ISSUER=SPECTRA
