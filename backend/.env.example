# ═══════════════════════════════════════════════════════════════════════════════
# SPECTRA — Backend Environment Variables
# Copy this file to .env and adjust for your environment.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development           # production | development | test
APP_DEBUG=true                # Set to false in production

# Secret used for Fernet encryption (TOTP secrets at rest).
# MUST be ≥ 32 random characters in production.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=dev-secret-key-change-in-production

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default for local development — zero setup):
# DATABASE_URL is unset → falls back to sqlite+aiosqlite:///./spectra.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://spectra:strongpassword@localhost:5432/spectra

# ── JWT ───────────────────────────────────────────────────────────────────────
# MUST be ≥ 32 random characters in production.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15      # Short-lived access token
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7         # Refresh token TTL
JWT_2FA_TEMP_EXPIRE_MINUTES=5           # TOTP challenge window

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production: ALLOWED_ORIGINS=https://spectra.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── TOTP / 2FA ────────────────────────────────────────────────────────────────
TOTP_ISSUER=SPECTRA

# ── Usage limits ─────────────────────────────────────────────────────────────
MAX_RUNS_PER_DAY=0            # 0 = unlimited; set e.g. 50 to cap usage per user
MAX_TARGETS=0                 # 0 = unlimited
MAX_RUN_TIMEOUT_SECONDS=120   # Maximum allowed request_timeout per run

# ── Data retention ───────────────────────────────────────────────────────────
DATA_RETENTION_DAYS=90        # Runs older than this are purged by the cleanup job
                               # Set to 0 to disable TTL

# ── Optional integrations ────────────────────────────────────────────────────
# Anthropic API key enables the SEMANTIC_PARAPHRASE mutation strategy.
# Leave empty to skip that strategy silently.
ANTHROPIC_API_KEY=

# ── Rate limiting ─────────────────────────────────────────────────────────────
# The in-process rate limiter (app/core/rate_limiter.py) uses sane defaults.
# For multi-worker production deployments, consider replacing it with Redis.
# No env vars needed — defaults: 5 req/IP/min on auth, 10 req/IP/hr on /config-scan
