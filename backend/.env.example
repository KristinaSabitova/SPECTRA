# SPECTRA backend environment variables
# Copy to .env and adjust as needed

# ── Application ───────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=dev-secret-key-change-in-production

# ── Database ──────────────────────────────────────────────────────────
# SQLite (default — no setup required):
# DATABASE_URL is not set, falls back to sqlite+aiosqlite:///./spectra.db

# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://spectra:spectra@localhost:5432/spectra

# ── CORS ─────────────────────────────────────────────────────────────
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET_KEY=dev-jwt-secret-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
